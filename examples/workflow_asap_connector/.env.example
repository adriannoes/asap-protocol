# Optional: live workflow HTTP API base URL (HTTPS recommended in production)
# ASAP_WORKFLOW_BASE_URL=https://your-host.example/api/v1

# Illustrative only — this demo does not read ASAP_WORKFLOW_BEARER_TOKEN.
# Wire live auth with resolve_headers reading this env var (see security guide).
# ASAP_WORKFLOW_BEARER_TOKEN=replace-me

# Illustrative only — for webhook signature / shared-secret verification when
# you add a callback receiver. Never commit a real secret.
# ASAP_WORKFLOW_WEBHOOK_SECRET=replace-me
