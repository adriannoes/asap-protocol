{
  "name": "@asap-protocol/mastra",
  "version": "2.4.1",
  "description": "ASAP Protocol capabilities as Mastra tools (@mastra/core)",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adriannoes/asap-protocol"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@asap-protocol/client": "^2.4.0",
    "@mastra/core": "^1.5.0",
    "zod": "^3.25.76 || ^4.1.8"
  },
  "dependencies": {},
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tshy",
    "test": "vitest run --coverage",
    "test:no-coverage": "vitest run",
    "lint": "eslint .",
    "check:treeshake": "pnpm run build && agadoo ./dist/esm/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@asap-protocol/client": "workspace:*",
    "@eslint/js": "9.18.0",
    "@mastra/core": "^1.35.0",
    "@types/node": "^20.19.0",
    "@vitest/coverage-v8": "4.1.5",
    "agadoo": "3.0.0",
    "eslint": "9.18.0",
    "tshy": "^3.3.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.59.1",
    "vitest": "^4.1.1",
    "zod": "^3.25.76"
  },
  "tshy": {
    "project": "./tsconfig.build.json",
    "exports": {
      ".": "./src/index.ts"
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    }
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js"
}
