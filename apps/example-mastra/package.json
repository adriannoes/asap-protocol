{
  "name": "example-mastra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "pnpm --filter @asap-protocol/client run build && pnpm --filter @asap-protocol/mastra run build && next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @asap-protocol/client run build && pnpm --filter @asap-protocol/mastra run build && tsc --noEmit",
    "compliance": "tsx scripts/compliance.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/react": "^3.0.176",
    "@asap-protocol/client": "workspace:*",
    "@asap-protocol/mastra": "workspace:*",
    "@mastra/core": "^1.35.0",
    "ai": "^6.0.174",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.14",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3"
  }
}
