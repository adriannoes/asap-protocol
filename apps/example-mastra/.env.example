# Copy to `.env.local` (gitignored). Do not commit secrets.

# Required: OpenAI-compatible key for @ai-sdk/openai used by Mastra routing.
OPENAI_API_KEY=

# ASAP gateway exposed to the browser (CORS required for browser → gateway registration).
NEXT_PUBLIC_ASAP_PROVIDER_URL=http://127.0.0.1:8080

# Audience for Agent JWT signing (defaults to provider origin when unset).
# NEXT_PUBLIC_ASAP_AUDIENCE=http://127.0.0.1:8080

# Comma-separated capability URNs offered to the Mastra tools.
NEXT_PUBLIC_ASAP_CAPABILITIES=urn:asap:cap:echo

# Used by LAB1-004 compliance script (`pnpm run compliance` from apps/example-mastra`).
ASAP_PROVIDER_URL=http://127.0.0.1:8080
