# Copy to `.env.local` (gitignored). Do not commit secrets.

# NODE_ENV=development

# LLM (required for chat)
OPENAI_API_KEY=

# ASAP gateway base URL used by the browser (must allow CORS from this app).
NEXT_PUBLIC_ASAP_PROVIDER_URL=http://localhost:8000

# OAuth-style audience for Host/Agent JWTs (defaults to provider URL origin if unset).
# NEXT_PUBLIC_ASAP_AUDIENCE=http://localhost:8000

# Comma-separated capability URNs offered to the model as tools.
NEXT_PUBLIC_ASAP_CAPABILITIES=urn:asap:cap:echo
